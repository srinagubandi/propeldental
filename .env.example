# =============================================================================
# PROPEL DENTAL - Environment Variables
# =============================================================================
#
# Copy this file to .env for local development
# Set these variables in your Railway dashboard for production deployment
#
# NEVER commit the actual .env file to git (it's in .gitignore)
#
# =============================================================================

# =============================================================================
# DATABASE (Required)
# =============================================================================
# MySQL/TiDB connection string provided by Railway or your database provider
DATABASE_URL=mysql://user:password@host:3306/propeldental

# =============================================================================
# AI CHAT (Required for AI chatbot feature)
# =============================================================================
# OpenAI API key for the AI patient assistant chatbot
OPENAI_API_KEY=sk-...

# =============================================================================
# ADMIN PANEL (Required)
# =============================================================================
# Credentials for the admin panel at /admin
# IMPORTANT: Use strong, unique credentials in production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# JWT secret for admin session tokens
# Generate with: openssl rand -hex 32
JWT_SECRET=your-random-secret-here

# =============================================================================
# LEAD NOTIFICATIONS (Optional but recommended)
# =============================================================================
# Email to receive new lead notifications
NOTIFICATION_EMAIL=hello@propel.dental

# Twilio SMS notifications (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
NOTIFY_PHONE_NUMBER=

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================
# Umami analytics (self-hosted or cloud)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# =============================================================================
# SERVER
# =============================================================================
PORT=3000
NODE_ENV=production
